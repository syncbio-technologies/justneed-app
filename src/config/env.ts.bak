import Constants from 'expo-constants';

export const getPublicEnv = (key: string): string | undefined => {
  const envValue = process.env[key];
  if (typeof envValue === 'string' && envValue.length > 0) {
    return envValue;
  }

  const expoConfig = Constants.expoConfig ?? (Constants.manifest as any);
  const extra = expoConfig?.extra;
  if (extra && typeof extra === 'object' && typeof extra[key] === 'string') {
    return extra[key];
  }

  return undefined;
};

export const getRequiredPublicEnv = (key: string): string => {
  const value = getPublicEnv(key);
  if (typeof value === 'string' && value.length > 0) {
    return value;
  }

  throw new Error(`Missing required public env variable: ${key}`);
};
