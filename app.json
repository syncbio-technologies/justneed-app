{
  "expo": {
    "name": "Justneed",
    "slug": "justneed-app",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "com.example.justneed",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1F3B"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.example.justneed",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.292474506519-linl9g6iqffpri165u2svl2414mbepkd"
            ]
          }
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "useNextNotificationFormat": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ],
      "package": "com.example.justneed",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.example.justneed"
            },
            {
              "scheme": "com.googleusercontent.apps.292474506519-kqd5d8k6gneqgfm9raq5r3ojpe6gm3lj"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to update your profile picture."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-system-ui",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static",
            "podfileProperties": {
              "use_modular_headers": true
            }
          }
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "owner": "drvenki",
    "extra": {
      "eas": {
        "projectId": "b17b4052-88d2-47c1-a4b0-62ec7d337bec"
      }
    }
  }
}
